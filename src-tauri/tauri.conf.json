{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ShallowHost",
  "version": "0.1.1",
  "identifier": "com.noktomezo.shallow-host",
  "mainBinaryName": "ShallowHost",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ShallowHost",
        "width": 900,
        "height": 700,
        "minWidth": 900,
        "minHeight": 700,
        "center": true,
        "decorations": false,
        "shadow": true,
        "backgroundColor": "#100F0F"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "publisher": "Noktomezo",
    "shortDescription": "VST2/VST3 plugin host for real-time audio processing",
    "longDescription": "Graphical shell for scanning, loading, and hosting VST2/VST3 plugins with real-time audio effect chains. Built on a JUCE AudioProcessorGraph backend with a Tauri + React frontend.",
    "copyright": "Copyright © 2026 Noktomezo",
    "targets": [
      "nsis"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "shallow_host_cpp.dll"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/Noktomezo/ShallowHost/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENCRUVFRjRGNEI2OTg2REEKUldUYWhtbExUKy91eXkvWkIvTlZja1pldmdSR3RVV1ZzeG1mVDhXc1hDR3J1VXU0ZitneitSelgK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
