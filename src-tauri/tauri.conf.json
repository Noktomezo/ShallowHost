{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ShallowHost",
  "version": "0.1.0",
  "identifier": "com.noktomezo.shallow-host",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ShallowHost",
        "width": 900,
        "height": 700,
        "minWidth": 900,
        "minHeight": 700,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "shallow_host_cpp.dll"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERGMzFGOENFRDUyRjAxQjQKUldTMEFTL1Z6dmd4MzFuRWlKaVJSeXBhRnAvTU9uMFVNby9NdTk1UVJyNVh0Qk5WZkpmWDNvYy8K"
    }
  }
}
